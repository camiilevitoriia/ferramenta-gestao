generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./banco.db"
}

model Usuario {
  id      String   @id @default(uuid())
  nome    String
  cargo   String
  tarefas Tarefa[]
}

model Tarefa {
  id             String   @id @default(uuid())
  titulo         String
  descricao      String
  situacao       String   // "A_FAZER", "EM_ANDAMENTO", "CONCLUIDO"
  dataVencimento DateTime
  usuarioId      String?
  responsavel    Usuario? @relation(fields: [usuarioId], references: [id])
}
